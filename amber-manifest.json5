{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {
      openai_api_key: { type: "string", secret: true },
      azure_openai_endpoint: { type: "string" },
    },
    required: ["openai_api_key", "azure_openai_endpoint"],
    additionalProperties: false,
  },

  program: {
    image: "ghcr.io/paulwhitten/agentwhetters-general-purple:latest",
    entrypoint: "uv run python src/server.py --host 0.0.0.0 --port 9009",

    env: {
      PYTHONUNBUFFERED: "1",
      AGENT_MODEL: "gpt-5.4",
      OPENAI_API_KEY: "${config.openai_api_key}",
      AZURE_OPENAI_ENDPOINT: "${config.azure_openai_endpoint}",
      AZURE_OPENAI_API_VERSION: "2025-04-01-preview",
    },

    network: {
      endpoints: [
        { name: "endpoint", port: 9009 },
      ],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" },
  },

  exports: { a2a: "a2a" },
}
