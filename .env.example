# Environment variables for AgentWhetters General Purple Agent
# Copy this file to .env and fill in your values

# --- Azure OpenAI (primary) ---
AZURE_OPENAI_ENDPOINT=https://agentwhetters-pcwhitte-ra.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-04-01-preview
OPENAI_API_KEY=your-azure-api-key

# --- Model deployment names ---
# Strong reasoning model (for main execution)
AGENT_MODEL=gpt-5.4
# Mid-tier model (for planning/analysis)
AGENT_MID_MODEL=gpt-4.1
# Cheap model (for simple tasks)
AGENT_CHEAP_MODEL=gpt-4o-mini

# --- Execution limits ---
# Max agentic loop steps
AGENT_STEP_LIMIT=30
# Shell command timeout in seconds
AGENT_COMMAND_TIMEOUT=120

# --- Logging ---
AGENT_LOG_LEVEL=INFO
